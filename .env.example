# --- DATABASE CONFIG ---
# Connection string for Neon PostgreSQL database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- STORAGE (CLOUDFLARE R2) ---
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"

# --- AUTH (CLERK) ---
# Publishable key used in the frontend
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
# Backend secret key
CLERK_SECRET_KEY="sk_test_..."
# Local bypass flag for development authentication (set to 'true' to bypass token validation)
CLERK_BYPASS_AUTH="false"

# --- GOOGLE WALLET CONFIG ---
GOOGLE_WALLET_ISSUER_ID=your_issuer_id
GOOGLE_WALLET_CLIENT_EMAIL=your_service_account_email
GOOGLE_WALLET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- APPLE WALLET CONFIG ---
APPLE_TEAM_ID=your_apple_team_id
APPLE_PASS_TYPE_ID=pass.com.yourdomain.card
# World-Wide Developer Relations (WWDR) Certificate in PEM format
WALLET_WWDR_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Pass Type ID signer certificate in PEM format
WALLET_SIGNER_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Pass Type ID signer private key in PEM format
WALLET_SIGNER_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WALLET_SIGNER_PASSPHRASE=""

# --- APPLE APNS CONFIG ---
# APNs Auth Key (p8 certificate content) in PEM format
APPLE_APNS_AUTH_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_APNS_KEY_ID="your_apns_key_id"

# --- STRIPE KEYS ---
# Your secret key from Developers > API Keys
STRIPE_SECRET_KEY="sk_test_..."
# Your signing secret from Developers > Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- STRIPE PRICE IDS ---
# Pro Tier
VITE_STRIPE_PRICE_PRO_MONTHLY="price_..."
VITE_STRIPE_PRICE_PRO_YEARLY="price_..."
# Pro Plus Tier
VITE_STRIPE_PRICE_PLUS_MONTHLY="price_..."
VITE_STRIPE_PRICE_PLUS_YEARLY="price_..."
# Business Tier
VITE_STRIPE_PRICE_BUSINESS_MONTHLY="price_..."
