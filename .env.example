# --- STRIPE KEYS ---
# Your secret key from Developers > API Keys
STRIPE_SECRET_KEY="sk_live_..."

# Your signing secret from Developers > Webhooks (Reveal when you create your endpoint)
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- STRIPE PRICE IDS ---
# Obtain these from the "Prices" section of each Product in your Stripe Dashboard.
# They usually look like: price_1PqR...

# Pro Tier
VITE_STRIPE_PRICE_PRO_MONTHLY="price_..."
VITE_STRIPE_PRICE_PRO_YEARLY="price_..."

# Pro Plus Tier
VITE_STRIPE_PRICE_PLUS_MONTHLY="price_..."
VITE_STRIPE_PRICE_PLUS_YEARLY="price_..."

# Business Tier (Used for webhook mapping)
VITE_STRIPE_PRICE_BUSINESS_MONTHLY="price_..."
