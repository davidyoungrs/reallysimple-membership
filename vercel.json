{
    "rewrites": [
        {
            "source": "/api/v1/(.*)",
            "destination": "/api/apple/v1/$1"
        },
        {
            "source": "/api/get-card-by-slug/(.*)",
            "destination": "/api/get-card-by-slug?slug=$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/passes.ts": {
            "includeFiles": "certs/model.pass/**"
        }
    }
}
