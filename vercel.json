{
    "rewrites": [
        {
            "source": "/api/v1/(.*)",
            "destination": "/api/apple-webhook?path=$1"
        },
        {
            "source": "/api/v1",
            "destination": "/api/apple-webhook?path="
        },
        {
            "source": "/api/get-card-by-slug/(.*)",
            "destination": "/api/get-card-by-slug?slug=$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/card/(.*)",
            "destination": "/api/public?resource=render-card&slug=$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/passes.ts": {
            "includeFiles": "certs/model.pass/**"
        }
    }
}